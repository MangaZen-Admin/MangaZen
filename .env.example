# Environment variables — copy to .env and fill with real values.
# .env.local is auto-ignored by Next.js; .env is committed with placeholders only.

# ─────────────────────────────────────────
# Base de datos (Neon PostgreSQL)
# ─────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─────────────────────────────────────────
# URLs del sitio
# ─────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# ─────────────────────────────────────────
# Autenticación
# ─────────────────────────────────────────
ACCESS_TOKEN_SECRET=your_secret_here

# ─────────────────────────────────────────
# Cloudinary (portadas y avatares)
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ─────────────────────────────────────────
# Cloudflare R2 (almacenamiento de capítulos)
# ─────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=mangazen
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─────────────────────────────────────────
# Resend (emails transaccionales)
# ─────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here

# ─────────────────────────────────────────
# Lemon Squeezy (pagos de Zen Coins)
# ─────────────────────────────────────────
LEMON_SQUEEZY_API_KEY=your_api_key_here
LEMON_SQUEEZY_STORE_ID=your_store_id_here
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# Variant IDs de cada paquete (se obtienen del dashboard de LS)
LEMON_SQUEEZY_VARIANT_MINI=your_variant_id_here
LEMON_SQUEEZY_VARIANT_STARTER=your_variant_id_here
LEMON_SQUEEZY_VARIANT_BASIC=your_variant_id_here
LEMON_SQUEEZY_VARIANT_PLUS=your_variant_id_here
LEMON_SQUEEZY_VARIANT_PRO=your_variant_id_here

# ─────────────────────────────────────────
# Cron jobs
# ─────────────────────────────────────────
CRON_SECRET=your_cron_secret_here

# ─────────────────────────────────────────
# PWA
# ─────────────────────────────────────────
# Colocar icon-192.png e icon-512.png en /public/ antes del deploy
# Tamaños requeridos: 192x192 y 512x512 píxeles